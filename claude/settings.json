{
  "cleanupPeriodDays": 90,
  "env": {
    "API_TIMEOUT_MS": "3000000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "70"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git stash *)",
      "Bash(git checkout *)",
      "Bash(git rebase *)",
      "Bash(git fetch *)",
      "Bash(git merge *)",
      "Bash(mix *)",
      "Bash(elixir *)",
      "Bash(iex *)",
      "Bash(npm test *)",
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(ffmpeg *)",
      "Bash(ffprobe *)",
      "Bash(jq *)",
      "Bash(brew *)",
      "Bash(python *)",
      "Bash(* --version)",
      "Bash(* --help)",
      "Bash(which *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(chmod *)",
      "Bash(shellcheck *)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(git push --force *)",
      "Bash(git push * --force *)",
      "Bash(git reset --hard *)",
      "Bash(git checkout . *)",
      "Bash(git clean -f *)"
    ]
  },
  "model": "sonnet",
  "worktree": {
    "symlinkDirectories": [
      "node_modules",
      "deps",
      "_build",
      ".elixir_ls"
    ]
  },
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-ansi"
}
